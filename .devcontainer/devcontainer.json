{
    "name": "EFT-OCR Dev Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "remoteUser": "devuser",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "cschlosser.doxdocgen",
                "littlefoxteam.vscode-python-test-adapter"
            ]
        }
    },
    "postCreateCommand": "pip install -r requirements.txt"
}

